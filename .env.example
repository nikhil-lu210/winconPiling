APP_NAME="YOUR_APP_NAME"
APP_ENV=development
APP_DEBUG=true
# Full base URL (no trailing slash, no /public). Match http vs https to the browser.
APP_URL=https://winconpiling.test
APP_TIMEZONE=Africa/Lagos

DB_PATH=database/wincon.db

ADMIN_SETUP_TOKEN=CHANGE_THIS_RANDOM_STRING_BEFORE_DEPLOY

SESSION_NAME=wincon_session
SESSION_LIFETIME=7200

UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

LOG_CHANNEL=file

# --- Mail (mapped in config/mail.php) — run: composer install ---
# Local (Laragon Pro Mailpit): start Mailpit, UI often http://127.0.0.1:8025 — use MAIL_MAILER=smtp and port 1025.
# Production: real SMTP host, MAIL_MAILER=smtp, TLS + credentials, MAIL_NOTIFY_ENABLED=1.
MAIL_NOTIFY_ENABLED=1
MAIL_NOTIFY_SENDER=1
MAIL_SENDER_SUBJECT=Thank you for contacting Wincon Pilling
MAIL_NOTIFY_TO=admin@example.com
MAIL_FROM=noreply@example.com
MAIL_MAILER=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=
SMTP_AUTH=0
